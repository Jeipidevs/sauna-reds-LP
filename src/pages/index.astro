---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FAQ from '../components/FAQ.astro';

const WA_NUMBER = '5551980437575';
const WA_URL = `https://wa.me/${WA_NUMBER}`;

const faqItems = [
  {
    question: 'Qual o horário de funcionamento da Sauna Reds?',
    answer: 'A Sauna Reds funciona de terça a sábado, das 14h às 5h da manhã. Aos domingos e segundas-feiras permanecemos fechados.',
  },
  {
    question: 'Onde fica a Sauna Reds em Capão da Canoa?',
    answer: 'Estamos localizados na Rua Alfa do Centauro, 720, bairro Arco Íris, Capão da Canoa – RS, CEP 95555-000 (Plus Code: 7X8V+9F). Temos estacionamento próprio para os clientes.',
  },
  {
    question: 'Como fazer reserva ou entrar em contato com a Sauna Reds?',
    answer: 'Entre em contato pelo nosso WhatsApp (51) 98043-7575 ou pelo e-mail redssauna@gmail.com. Atendemos de terça a sábado a partir das 14h.',
  },
  {
    question: 'Qual a programação semanal da Sauna Reds?',
    answer: 'Nossa programação inclui: Terça da Calmaria, Quarta do Prazer, Quinta do TBT, Sexta da Maldade e Sábado do Bailão. Cada noite tem sua temática exclusiva. Domingo e segunda estamos fechados.',
  },
  {
    question: 'A Sauna Reds é exclusiva para maiores de 18 anos?',
    answer: 'Sim, a Sauna Reds é um estabelecimento de entretenimento adulto exclusivo para maiores de 18 anos. É obrigatório apresentar documento de identificação na entrada.',
  },
  {
    question: 'A Sauna Reds tem acompanhantes e cardápio de bebidas?',
    answer: 'Sim, contamos com acompanhantes sofisticadas e um cardápio completo com cervejas, espumantes, drinks artesanais e combos especiais. Consulte pelo WhatsApp para mais informações.',
  },
];

const nights = [
  { day: 'Terça-Feira',  name: 'Terça da Calmaria', tag: 'Tranquilo', icon: '🌊', desc: 'Uma noite suave para relaxar e se conhecer num ambiente intimista e aconchegante.' },
  { day: 'Quarta-Feira', name: 'Quarta do Prazer',  tag: 'Especial',  icon: '🔥', desc: 'A noite esquenta na metade da semana com programação diferenciada e exclusiva.' },
  { day: 'Quinta-Feira', name: 'Quinta do TBT',     tag: 'Nostalgia', icon: '🎵', desc: 'As melhores músicas de ontem num clima saudosista e cheio de sedução.' },
  { day: 'Sexta-Feira',  name: 'Sexta da Maldade',  tag: 'Hot',       icon: '😈', desc: 'A noite mais aguardada da semana. Venha preparado para o inesperado.' },
  { day: 'Sábado',       name: 'Sábado do Bailão',  tag: 'Animado',   icon: '🎉', desc: 'Muita música, dança e diversão até o amanhecer. O melhor do final de semana.' },
];


const menu = [
  { img: 'drinks-cerveja', name: 'Cerveja',   desc: 'Seleção premium de cervejas nacionais e importadas, geladas na temperatura ideal.',          price: 'A partir de R$ 10' },
  { img: 'drinks-heineken',name: 'Heineken',  desc: 'A famosa Heineken gelada do jeito que você gosta, servida com estilo e sofisticação.',        price: 'A partir de R$ 12' },
  { img: 'drinks-whisky',  name: 'Whisky',    desc: 'Johnnie Walker e outras opções premium para quem aprecia um bom drinque com classe.',         price: 'A partir de R$ 35' },
  { img: 'drinks-redbull', name: 'Energy',    desc: 'Red Bull e energéticos para manter o ritmo até o amanhecer com toda a energia.',              price: 'A partir de R$ 15' },
];

const companions = [
  { img: 'acomp-pole',    name: 'Pole Dance',  tag: 'Show exclusivo toda semana' },
  { img: 'acomp-branca',  name: 'Estilo',      tag: 'Sofisticação e elegância'   },
  { img: 'acomp-lingerie',name: 'Sensualidade',tag: 'Ambiente intimista premium'  },
  { img: 'suite',         name: 'Suíte',       tag: 'Espaços privativos'          },
];
---

<Layout
  title="Sauna Reds – Boate em Capão da Canoa RS | Terça a Sábado"
  description="Boate e casa noturna em Capão da Canoa, RS. Programação especial de terça a sábado, das 14h às 5h. WhatsApp (51) 98043-7575."
  faqItems={faqItems}
>

  <!-- ── HERO ─────────────────────────────────────── -->
  <Hero />

  <!-- ── HORÁRIOS ──────────────────────────────────── -->
  <section id="horarios" style="background:var(--surface)">
    <div class="container">
      <div class="sec-header">
        <span class="sec-eyebrow reveal">Funcionamento</span>
        <h2 class="sec-title reveal d1">Horários de <span>Atendimento</span></h2>
        <div class="sec-divider reveal d2"></div>
      </div>
      <div class="hours-grid">
        {[
          { icon: '📅', label: 'Dias da Semana', value: 'Terça a Sábado',   desc: 'Domingo e segunda estamos fechados' },
          { icon: '🌅', label: 'Abertura',        value: '14h da tarde',     desc: 'Venha cedo e aproveite o happy hour' },
          { icon: '🌙', label: 'Encerramento',    value: '5h da manhã',      desc: 'A festa vai até o amanhecer' },
          { icon: '📱', label: 'Reservas',        value: 'Via WhatsApp',     desc: 'Garanta seu espaço com antecedência' },
        ].map((h, i) => (
          <div class={`glass hour-card reveal d${i + 1}`}>
            <div class="hour-icon">{h.icon}</div>
            <div class="hour-label">{h.label}</div>
            <div class="hour-value">{h.value}</div>
            <div class="hour-desc">{h.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROGRAMAÇÃO ───────────────────────────────── -->
  <section id="programacao" style="background:var(--bg)">
    <div class="container">
      <div class="sec-header">
        <span class="sec-eyebrow reveal">Toda Semana</span>
        <h2 class="sec-title reveal d1">Nossa <span>Programação</span></h2>
        <div class="sec-divider reveal d2"></div>
        <p class="sec-desc reveal d3">
          Cada noite tem sua própria identidade. Escolha a sua favorita ou venha em todas!
        </p>
      </div>
      <div class="nights-grid">
        {nights.map((n, i) => (
          <article class={`glass night-card reveal d${Math.min(i,4)}`}>
            <div class="night-icon">{n.icon}</div>
            <div class="night-day">{n.day}</div>
            <h3 class="night-name">{n.name}</h3>
            <span class="night-tag">{n.tag}</span>
            <p class="night-desc">{n.desc}</p>
          </article>
        ))}
      </div>
      <div class="text-center" style="margin-top:2.5rem">
        <a href="/programacao" class="btn-outline reveal">Ver Programação Completa</a>
      </div>
    </div>
  </section>

  <!-- ── CARDÁPIO ──────────────────────────────────── -->
  <section id="cardapio" style="background:var(--surface)">
    <div class="container">
      <div class="sec-header">
        <span class="sec-eyebrow reveal">Bebidas & Drinks</span>
        <h2 class="sec-title reveal d1">Nosso <span>Cardápio</span></h2>
        <div class="sec-divider reveal d2"></div>
      </div>
      <div class="menu-grid">
        {menu.map((m, i) => (
          <div class={`glass menu-card reveal d${i}`} style="padding:0;overflow:hidden">
            <div class="menu-img">
              <picture>
                <source srcset={`/images/${m.img}.webp`} type="image/webp" />
                <img src={`/images/${m.img}.jpg`} alt={m.name} loading="lazy" decoding="async" width="600" height="400" />
              </picture>
            </div>
            <div class="menu-body">
              <h3 class="menu-name">{m.name}</h3>
              <p class="menu-desc">{m.desc}</p>
              <div class="menu-price">{m.price}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ACOMPANHANTES ─────────────────────────────── -->
  <section id="acompanhantes" style="background:var(--bg)">
    <div class="container">
      <div class="sec-header">
        <span class="sec-eyebrow reveal">Conheça</span>
        <h2 class="sec-title reveal d1">Nossas <span>Acompanhantes</span></h2>
        <div class="sec-divider reveal d2"></div>
        <p class="sec-desc reveal d3">
          Mulheres sofisticadas e elegantes para tornar sua noite ainda mais especial.
        </p>
      </div>
      <div class="companions-grid">
        {companions.map((c, i) => (
          <div class={`glass companion-card reveal d${i}`} style="padding:0">
            <div class="companion-img" aria-label={c.tag}>
              <picture>
                <source srcset={`/images/${c.img}.webp`} type="image/webp" />
                <img src={`/images/${c.img}.jpg`} alt={c.name} loading="lazy" decoding="async" width="600" height="800" />
              </picture>
            </div>
            <div class="companion-body">
              <div class="companion-name">{c.name}</div>
              <div class="companion-tag">{c.tag}</div>
              <a
                href={WA_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="companion-btn"
                aria-label={`Chamar ${c.name} no WhatsApp`}
              >
                Chamar no WhatsApp
              </a>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top:2.5rem">
        <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-primary reveal">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Ver Todas no WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ── SOBRE (snippet) ────────────────────────────── -->
  <section id="sobre-home" style="background:var(--surface);position:relative;overflow:hidden">
    <div class="about-glow" aria-hidden="true"></div>
    <div class="container">
      <div class="about-layout">
        <div class="about-text">
          <span class="sec-eyebrow reveal">Nossa História</span>
          <h2 class="sec-title reveal d1" style="text-align:left;margin-bottom:1.4rem">
            20 anos de <em style="font-style:italic;color:var(--red-bright)">história</em><br />e tradição em Capão da Canoa
          </h2>
          <p class="about-body reveal d2">
            A Sauna Reds é referência em entretenimento adulto em Capão da Canoa, no Litoral Norte do Rio Grande do Sul. Por mais de duas décadas, construímos uma reputação de excelência, sofisticação e respeito.
          </p>
          <p class="about-body reveal d3">
            Seja para relaxar depois de um longo dia, curtir uma noite especial ou explorar novas experiências — a Sauna Reds oferece tudo o que você precisa num ambiente seguro e elegante.
          </p>
          <div class="about-stats reveal d4">
            <div class="stat"><div class="stat-num">20+</div><div class="stat-label">Anos de História</div></div>
            <div class="stat"><div class="stat-num">50k+</div><div class="stat-label">Clientes Satisfeitos</div></div>
            <div class="stat"><div class="stat-num">6×</div><div class="stat-label">Por Semana</div></div>
          </div>
          <a href="/sobre" class="btn-primary reveal d5" style="margin-top:2rem;display:inline-flex">
            Conhecer Nossa História
          </a>
        </div>
        <div class="about-gallery reveal d2">
          <div class="gallery-img">
            <picture>
              <source srcset="/images/salao.webp" type="image/webp" />
              <img src="/images/salao.jpg" alt="Salão principal da Sauna Reds" loading="lazy" decoding="async" width="900" height="1200" />
            </picture>
          </div>
          <div class="gallery-img">
            <picture>
              <source srcset="/images/recepcao.webp" type="image/webp" />
              <img src="/images/recepcao.jpg" alt="Recepção da Sauna Reds" loading="lazy" decoding="async" width="800" height="1067" />
            </picture>
          </div>
          <div class="gallery-img">
            <picture>
              <source srcset="/images/neon-viva.webp" type="image/webp" />
              <img src="/images/neon-viva.jpg" alt="Ambiente interno da Sauna Reds" loading="lazy" decoding="async" width="800" height="1067" />
            </picture>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────── -->
  <FAQ items={faqItems} title="Dúvidas Frequentes" eyebrow="FAQ — Sauna Reds Capão da Canoa" />

  <!-- ── CTA FINAL ──────────────────────────────────── -->
  <section style="background:var(--bg);text-align:center">
    <div class="container" style="max-width:680px">
      <span class="sec-eyebrow reveal">Venha nos Visitar</span>
      <h2 class="sec-title reveal d1" style="margin-bottom:1rem">
        Sua próxima noite<br /><span>inesquecível</span> começa aqui
      </h2>
      <p class="reveal d2" style="color:var(--muted);margin-bottom:2rem;line-height:1.8">
        Rua Alfa do Centauro, 720, Arco Íris · Capão da Canoa, RS<br />
        Terça a Sábado · 14h às 5h
      </p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap" class="reveal d3">
        <a href={WA_URL} target="_blank" rel="noopener" class="btn-primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Reservar pelo WhatsApp
        </a>
        <a href="/contato" class="btn-outline">Ver no Mapa</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hours ──────────────────────────── */
  .hours-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.4rem;
  }
  .hour-card { text-align: center; }
  .hour-icon { font-size: 2.4rem; margin-bottom: 0.9rem; }
  .hour-label { font-size: var(--fs-13); letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .hour-value { font-family: "lora", serif; font-size: 1.55rem; font-weight: 700; }
  .hour-desc  { color: var(--muted); font-size: 0.82rem; margin-top: 0.45rem; }

  /* ── Nights ─────────────────────────── */
  .nights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(185px, 1fr));
    gap: 1.2rem;
  }
  .night-card { text-align: center; }
  .night-icon { font-size: 2rem; margin-bottom: 0.65rem; }
  .night-day  { font-size: var(--fs-13); letter-spacing: 0.24em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .night-name { font-size: 1.25rem; margin-bottom: 0.65rem; }
  .night-tag  { display: inline-block; background: var(--red); color: #fff; font-size: var(--fs-13); font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.22rem 0.7rem; border-radius: 20px; }
  .night-desc { color: var(--muted); font-size: var(--fs-13); margin-top: 0.7rem; line-height: 1.6; }

  /* ── Menu ───────────────────────────── */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(215px, 1fr));
    gap: 1.4rem;
  }
  .menu-card  { text-align: center; }
  .menu-img   { aspect-ratio: 4/3; overflow: hidden; }
  .menu-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .menu-card:hover .menu-img img { transform: scale(1.05); }
  .menu-body  { padding: 1.2rem; }
  .menu-name  { font-size: 1.35rem; margin-bottom: 0.5rem; }
  .menu-desc  { color: var(--muted); font-size: 0.83rem; line-height: 1.65; }
  .menu-price { margin-top: 0.9rem; color: var(--gold); font-weight: 600; font-size: 0.82rem; }

  /* ── Companions ─────────────────────── */
  .companions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(195px, 1fr));
    gap: 1.2rem;
  }
  .companion-card    { overflow: hidden; }
  .companion-img     { width: 100%; aspect-ratio: 3/4; overflow: hidden; border-radius: 8px 8px 0 0; }
  .companion-img img { width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: transform 0.5s; }
  .companion-card:hover .companion-img img { transform: scale(1.06); }
  .companion-body    { padding: 1.1rem; }
  .companion-name    { font-family: "lora", serif; font-size: 1.05rem; font-weight: 600; }
  .companion-tag     { color: var(--gold); font-size: 0.72rem; margin-top: 0.2rem; }
  .companion-btn     { display: block; width: 100%; margin-top: 0.9rem; background: transparent; border: 1px solid var(--red); color: var(--red); padding: 0.48rem; border-radius: 4px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; text-decoration: none; transition: all 0.2s; text-align: center; }
  .companion-btn:hover { background: var(--red); color: #fff; }

  /* ── About ──────────────────────────── */
  .about-glow { position: absolute; top: 0; right: 0; width: 600px; height: 600px; background: radial-gradient(circle, rgba(204,0,0,0.055) 0%, transparent 70%); pointer-events: none; }
  .about-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; position: relative; z-index: 1; }
  @media (max-width: 768px) { .about-layout { grid-template-columns: 1fr; } }
  .about-body   { color: var(--muted); line-height: 1.85; font-size: 0.93rem; margin-bottom: 1.2rem; }
  .about-stats  { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-top: 2rem; }
  .stat         { text-align: center; }
  .stat-num     { font-family: "lora", serif; font-size: 2.1rem; font-weight: 700; color: var(--gold); }
  .stat-label   { font-size: var(--fs-13); letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-top: 0.2rem; }
  .about-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
  .gallery-img   { border-radius: 8px; border: 1px solid rgba(212,175,55,0.1); overflow: hidden; aspect-ratio: 4/3; transition: border-color 0.3s; }
  .gallery-img:first-child { grid-column: 1 / -1; aspect-ratio: 16/7; }
  .gallery-img:hover { border-color: rgba(204,0,0,0.4); }
  .gallery-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .gallery-img:hover img { transform: scale(1.04); }

  /* ── Utils ──────────────────────────── */
  .sec-desc { color: var(--muted); font-size: 0.9rem; max-width: 500px; margin: 0.75rem auto 0; line-height: 1.75; }
  .text-center { text-align: center; }
</style>
