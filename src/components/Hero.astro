---
const WA_URL = 'https://wa.me/5551980437575';
---

<section id="hero" aria-label="Bem-vindo à Sauna Reds">
  <!-- Real photo background — fetchpriority high for LCP -->
  <picture class="hero-bg-wrap" aria-hidden="true">
    <source srcset="/images/hero-bg.webp" type="image/webp" />
    <img
      src="/images/hero-bg.jpg"
      alt=""
      class="hero-bg-img"
      fetchpriority="high"
      loading="eager"
      decoding="async"
      width="1920"
      height="1080"
    />
  </picture>
  <!-- CSS atmospheric orbs on top of photo -->
  <div class="hero-atmosphere" aria-hidden="true">
    <div class="atm-orb atm-1"></div>
    <div class="atm-orb atm-2"></div>
    <div class="atm-orb atm-3"></div>
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="hero-eyebrow reveal">Capão da Canoa · Rio Grande do Sul</p>
    <h1 class="hero-title reveal d1">
      Sauna Reds —<br />
      <em>prazer e sofisticação</em><br />
      em Capão da Canoa
    </h1>
    <p class="hero-sub reveal d2">
      A casa noturna mais exclusiva de Capão da Canoa.
      Programação especial toda semana, de terça a sábado, das 14h às 5h.
    </p>
    <div class="hero-btns reveal d3">
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Falar no WhatsApp
      </a>
      <a href="/sobre" class="btn-outline">Conhecer o Espaço</a>
    </div>
  </div>

  <a href="#horarios" class="hero-scroll" aria-label="Rolar para baixo">
    <span>Rolar</span>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<style>
  #hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 7rem 1.5rem 5rem;
  }

  /* Real photo background */
  .hero-bg-wrap {
    position: absolute;
    inset: 0;
    display: block;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  /* CSS-only atmospheric orbs — zero JS, GPU-composited (transform+opacity only) */
  .hero-atmosphere {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .atm-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform, opacity;
  }

  .atm-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(204,0,0,0.18) 0%, transparent 70%);
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
  }

  .atm-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(212,175,55,0.1) 0%, transparent 70%);
    bottom: 10%;
    right: 5%;
  }

  .atm-3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(204,0,0,0.1) 0%, transparent 70%);
    bottom: 20%;
    left: 5%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .atm-1 { animation: orb-drift-center 10s ease-in-out infinite alternate; }
    .atm-2 { animation: orb-drift 14s ease-in-out infinite alternate-reverse; }
    .atm-3 { animation: orb-drift 12s ease-in-out infinite alternate; }
  }

  @keyframes orb-drift {
    from { opacity: 0.7; transform: translateY(0) scale(1); }
    to   { opacity: 1;   transform: translateY(-30px) scale(1.08); }
  }

  @keyframes orb-drift-center {
    from { opacity: 0.7; transform: translateX(-50%) translateY(0) scale(1); }
    to   { opacity: 1;   transform: translateX(-50%) translateY(-20px) scale(1.06); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,10,10,0.75) 0%,
      rgba(10,10,10,0.72) 50%,
      rgba(10,10,10,0.95) 100%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .hero-eyebrow {
    font-size: var(--fs-13);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    display: block;
  }

  .hero-title {
    font-size: clamp(var(--fs-34), 9vw, var(--fs-89));
    color: var(--text);
    margin-bottom: 1.2rem;
  }

  .hero-title em {
    font-style: italic;
    color: var(--red-bright);
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, var(--fs-34));
    color: var(--muted);
    max-width: 680px;
    margin: 0 auto 2.5rem;
    font-weight: 300;
    line-height: 1.618;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    z-index: 2;
    animation: scroll-bounce 2.2s ease-in-out infinite;
    transition: color 0.2s;
  }

  .hero-scroll:hover { color: var(--gold); }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
  }

  /* Immediately reveal hero on load */
  #hero .reveal { opacity: 1; transform: none; }
</style>

<script>
  // Stagger hero reveals after page load
  window.addEventListener('load', () => {
    const els = document.querySelectorAll('#hero .reveal');
    els.forEach((el, i) => {
      setTimeout(() => el.classList.add('visible'), 150 + i * 120);
    });
  });
</script>
